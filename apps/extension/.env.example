# ── Server ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/leetconnect?sslmode=require
REDIS_URL=rediss://default:token@host:6380

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

JWT_SECRET=change-me-in-production-at-least-32-chars
JWT_REFRESH_SECRET=another-long-secret-for-refresh-tokens

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID,http://localhost:5173

PORT=3001
NODE_ENV=development

# ── Extension ────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=ws://localhost:3001
VITE_GOOGLE_CLIENT_ID=your-google-client-id
