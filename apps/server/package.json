{
  "name": "@leetconnect/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@neondatabase/serverless": "^0.9.5",
    "arctic": "^2.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.31.4",
    "fastify": "^5.0.0",
    "fastify-plugin": "^4.5.1",
    "jose": "^5.4.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.22.8",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^3.2.4"
  }
}
